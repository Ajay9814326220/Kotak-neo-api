# Kotak Securities API Credentials
KOTAK_API_KEY=your_api_key_here
KOTAK_API_SECRET=your_api_secret_here
KOTAK_CLIENT_CODE=your_client_code_here
KOTAK_MPIN=your_mpin_here
KOTAK_PKZ=your_pkz_here

# TOTP Configuration
# Get this from scanning QR code in Kotak Neo app
KOTAK_TOTP_SECRET=your_totp_secret_here

# API Configuration
KOTAK_BASE_URL=https://api.kotaksecurities.com
KOTAK_API_VERSION=v1

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/kotak_api.log

# Environment
ENVIRONMENT=sandbox  # Change to 'production' for live trading